---
import { type Locale, DEFAULT_LOCALE } from '../i18n/locales';
import { t } from '../i18n/strings';

interface Props { lang?: Locale; }
const { lang = DEFAULT_LOCALE } = Astro.props;
const s = t(lang);
const homeHref = lang === DEFAULT_LOCALE ? '/' : `/${lang}/`;
---

<section class="not-found">
  <div class="container is-narrow">
    <span class="eyebrow">{s.not_found.eyebrow}</span>
    <h1>{s.not_found.h1}</h1>
    <p class="lead">{s.not_found.lead}</p>
    <div class="not-found-actions">
      <a href={homeHref} class="btn btn--primary btn--lg">
        <span>{s.not_found.cta_home}</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a href="tel:+33763277878" class="btn btn--ghost btn--lg">
        <span>07 63 27 78 78</span>
      </a>
    </div>
  </div>
</section>

<style>
  .not-found {
    padding-block: var(--s-10) var(--s-9);
    min-height: 70vh;
    display: flex;
    align-items: center;
    text-align: center;
  }
  .not-found .eyebrow { margin-bottom: var(--s-3); display: block; }
  .not-found h1 { font-size: var(--step-6); margin-bottom: var(--s-4); }
  .not-found .lead { margin: 0 auto var(--s-6); max-width: 48ch; }
  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    justify-content: center;
  }
  @media (min-width: 720px) {
    .not-found h1 { font-size: var(--step-7); }
    .not-found .lead { margin-bottom: var(--s-7); }
  }
</style>
