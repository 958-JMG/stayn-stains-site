---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { LOCALE_HTML, LOCALE_LABELS, type Locale, DEFAULT_LOCALE } from '../i18n/locales';
import { t } from '../i18n/strings';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: Locale;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.jpg',
  noindex = false,
  lang = DEFAULT_LOCALE,
} = Astro.props;

const dir = LOCALE_LABELS[lang].dir;
const htmlLang = LOCALE_HTML[lang];
const ogLocale = htmlLang.replace('-', '_');

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const strings = t(lang);

const path = Astro.url.pathname;

function buildBreadcrumbs(p: string) {
  const home = lang === DEFAULT_LOCALE
    ? 'https://www.stayn-stains.fr/'
    : `https://www.stayn-stains.fr/${lang}/`;
  const base = { '@type': 'ListItem', position: 1, name: strings.nav.programme === 'The project' ? 'Home' : strings.nav.programme === 'المشروع' ? 'الرئيسيّة' : 'Accueil', item: home };
  const trail: any[] = [base];
  const segs = p.split('/').filter(Boolean).filter((s) => !['fr','en','ar'].includes(s));
  let acc = lang === DEFAULT_LOCALE ? '' : `/${lang}`;
  const labelsByLang: Record<Locale, Record<string, string>> = {
    fr: { 'mentions-legales': 'Mentions légales', merci: 'Merci' },
    en: { 'mentions-legales': 'Legal notice', merci: 'Thank you' },
    ar: { 'mentions-legales': 'الإشعار القانوني', merci: 'شكراً' },
  };
  segs.forEach((seg, i) => {
    acc += '/' + seg;
    const label = labelsByLang[lang][seg] || seg;
    trail.push({
      '@type': 'ListItem',
      position: i + 2,
      name: label,
      item: `https://www.stayn-stains.fr${acc}/`,
    });
  });
  return trail;
}
const breadcrumbs = buildBreadcrumbs(path);

// Hreflang : pointer toujours vers les 3 versions de la page courante
import { localizedTwin, LOCALES } from '../i18n/locales';
const hreflangs = LOCALES.map((l) => ({
  hreflang: LOCALE_HTML[l],
  href: new URL(localizedTwin(path, l), Astro.site).toString(),
}));
---

<!DOCTYPE html>
<html lang={htmlLang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {hreflangs.map((h) => (
      <link rel="alternate" hreflang={h.hreflang} href={h.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(localizedTwin(path, 'fr'), Astro.site).toString()} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#FBF8F4" />

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Stay'n Stains" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'ApartmentComplex',
        '@id': 'https://www.stayn-stains.fr/#residence',
        name: "Stay'n",
        description: strings.meta.desc_home,
        url: 'https://www.stayn-stains.fr',
        image: 'https://www.stayn-stains.fr/og-image.jpg',
        numberOfAccommodationUnits: 58,
        address: {
          '@type': 'PostalAddress',
          streetAddress: '7-11 avenue Marcel Cachin',
          addressLocality: 'Stains',
          postalCode: '93240',
          addressCountry: 'FR',
        },
        geo: { '@type': 'GeoCoordinates', latitude: 48.9521, longitude: 2.3873 },
        provider: {
          '@type': 'Organization',
          name: 'CD LINK Promotion',
          url: 'https://cdlink-promotion.com',
        },
      })}
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs,
      })}
    />

    <script defer data-domain="stayn-stains.fr" src="https://plausible.io/js/script.js"></script>

    <ClientRouter />
  </head>

  <body>
    <a href="#main" class="skip-link">{strings.nav.skip_to_main}</a>

    <Header lang={lang} />

    <main id="main" role="main">
      <slot />
    </main>

    <Footer lang={lang} />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
      );

      function bindReveal() {
        document.querySelectorAll('.reveal:not(.is-visible)').forEach((el, i) => {
          if (el instanceof HTMLElement) {
            const container = el.parentElement;
            if (container?.classList.contains('reveal-stagger')) {
              el.style.setProperty('--i', String(i));
            }
          }
          io.observe(el);
        });
      }

      bindReveal();
      document.addEventListener('astro:page-load', bindReveal);
    </script>
  </body>
</html>

<style is:global>
  html { scroll-padding-top: calc(var(--header-h) + 16px); }
  main { min-height: 60vh; padding-top: var(--header-h); }
</style>
