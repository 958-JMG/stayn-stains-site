# Copier ce fichier en .env (gitignored) et y mettre les vraies valeurs.
#
# Clé Google Maps (frontend) — utilisée par MapPOI.astro pour Static Maps.
# Doit être restreinte par HTTP referrer côté Google Cloud Console :
#   *.stayn-stains.fr/*
#   *.pages.dev/*
#   localhost:4321/*
PUBLIC_GOOGLE_MAPS_KEY=
